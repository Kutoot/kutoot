###############################################
# KUTOOT PRODUCTION .env - File Upload Fixes Applied
# Copy relevant sections to your .env
###############################################

# === FILESYSTEM / S3 (required for uploads) ===
FILESYSTEM_DRIVER=s3
FILESYSTEM_DISK=s3

AWS_BUCKET=kutoot-backend
AWS_DEFAULT_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_URL=https://kutoot-backend.s3.ap-south-1.amazonaws.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# Media Library: use 'public' so URLs go through /storage stream route (works with private S3)
MEDIA_DISK=public

# Upload sizes: UPLOAD_MAX_FILE_SIZE is in KB (102400 = 100MB)
UPLOAD_MAX_FILE_SIZE=102400
MEDIA_MAX_FILE_SIZE=104857600
